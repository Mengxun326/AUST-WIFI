  <property name="styleSheet">
   <string notr="true">/* Windows 11 Fluent Design Style */
QMainWindow {
    background-color: #F3F3F3;
    font-family: "Segoe UI Variable", "Segoe UI", -apple-system, BlinkMacSystemFont, sans-serif;
}

QWidget#centralwidget {
    background: transparent;
}

/* 卡片样式 */
QFrame#statusCard, QFrame#infoCard, QFrame#actionCard {
    background-color: #FFFFFF;
    border: none;
    border-radius: 8px;
    padding: 0px;
}

/* 标题样式 */
QLabel#titleLabel {
    font-size: 28px;
    font-weight: 600;
    color: #202020;
    background: transparent;
    border: none;
    padding: 0px;
}

QLabel#subtitleLabel {
    font-size: 14px;
    font-weight: 400;
    color: #606060;
    background: transparent;
    border: none;
    padding: 0px;
}

/* 状态标签 */
QLabel#statusTitleLabel {
    font-size: 12px;
    font-weight: 600;
    color: #606060;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    background: transparent;
    border: none;
    padding: 0px;
}

QLabel#statusValueLabel {
    font-size: 16px;
    font-weight: 500;
    color: #202020;
    background: transparent;
    border: none;
    padding: 0px;
}

QLabel#statusDescriptionLabel {
    font-size: 13px;
    font-weight: 400;
    color: #606060;
    background: transparent;
    border: none;
    padding: 0px;
}

/* WiFi信息标签 */
QLabel#wifiNameLabel, QLabel#userTypeLabel, QLabel#lastLoginLabel {
    font-size: 13px;
    font-weight: 400;
    color: #606060;
    background: transparent;
    border: none;
    padding: 0px;
}

QLabel#wifiNameValue, QLabel#userTypeValue, QLabel#lastLoginValue {
    font-size: 14px;
    font-weight: 500;
    color: #202020;
    background: transparent;
    border: none;
    padding: 0px;
}

/* 按钮样式 - Windows 11风格 */
QPushButton#configButton {
    background-color: #0078D4;
    border: none;
    border-radius: 4px;
    color: #FFFFFF;
    font-size: 14px;
    font-weight: 500;
    padding: 10px 24px;
    min-height: 36px;
}

QPushButton#configButton:hover {
    background-color: #106EBE;
}

QPushButton#configButton:pressed {
    background-color: #005A9E;
}

QPushButton#toggleButton {
    background-color: #107C10;
    border: none;
    border-radius: 4px;
    color: #FFFFFF;
    font-size: 14px;
    font-weight: 500;
    padding: 10px 24px;
    min-height: 36px;
}

QPushButton#toggleButton:hover {
    background-color: #0E6E0E;
}

QPushButton#toggleButton:pressed {
    background-color: #0C5D0C;
}

QPushButton#toggleButton.stopped {
    background-color: transparent;
    border: 1px solid #E1E1E1;
    color: #202020;
}

QPushButton#toggleButton.stopped:hover {
    background-color: #F9F9F9;
    border-color: #C1C1C1;
}

QPushButton#toggleButton.stopped:pressed {
    background-color: #F3F3F3;
}

/* 状态指示器 */
QLabel#statusIndicator {
    min-width: 12px;
    max-width: 12px;
    min-height: 12px;
    max-height: 12px;
    border-radius: 6px;
    background-color: #107C10;
}

QLabel#statusIndicator.disconnected {
    background-color: #D13438;
}

QLabel#statusIndicator.connecting {
    background-color: #FFB900;
}

/* 分隔线 */
QFrame#divider {
    background-color: #E1E1E1;
    max-height: 1px;
    min-height: 1px;
    border: none;
}

/* 状态栏 */
QStatusBar {
    background-color: #FAFAFA;
    border-top: 1px solid #E1E1E1;
    color: #606060;
    font-size: 12px;
    padding: 4px 8px;
}</string>
