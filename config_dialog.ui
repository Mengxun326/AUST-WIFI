  <property name="styleSheet">
   <string notr="true">/* Windows 11 Fluent Design Style - Config Dialog */
QDialog {
    background-color: #F3F3F3;
    font-family: "Segoe UI Variable", "Segoe UI", -apple-system, BlinkMacSystemFont, sans-serif;
}

/* 卡片样式 */
QFrame#headerCard, QFrame#contentCard {
    background-color: #FFFFFF;
    border: none;
    border-radius: 8px;
    padding: 0px;
}

/* 标题样式 */
QLabel#dialogTitleLabel {
    font-size: 24px;
    font-weight: 600;
    color: #202020;
    background: transparent;
    border: none;
    padding: 0px;
}

QLabel#dialogSubtitleLabel {
    font-size: 14px;
    font-weight: 400;
    color: #606060;
    background: transparent;
    border: none;
    padding: 0px;
}

/* 选项卡样式 - Windows 11风格 */
QTabWidget::pane {
    border: none;
    background-color: #FFFFFF;
    border-radius: 8px;
    margin-top: -1px;
    min-height: 400px;
}

QTabBar::tab {
    background-color: transparent;
    color: #606060;
    font-size: 14px;
    font-weight: 500;
    padding: 12px 24px;
    border: none;
    border-bottom: 2px solid transparent;
    min-width: 120px;
}

QTabBar::tab:selected {
    color: #0078D4;
    border-bottom: 2px solid #0078D4;
    background-color: transparent;
}

QTabBar::tab:hover:!selected {
    color: #202020;
    background-color: #F9F9F9;
}

QTabBar::tab:first {
    margin-left: 0px;
}

/* 分组框样式 */
QGroupBox {
    border: none;
    border-radius: 8px;
    background-color: #FAFAFA;
    margin-top: 8px;
    padding-top: 20px;
    font-size: 14px;
    font-weight: 600;
    color: #202020;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top;
    left: 16px;
    padding: 0px 8px;
    background-color: #FAFAFA;
    color: #202020;
    font-size: 14px;
    font-weight: 600;
}

/* 标签样式 */
QLabel {
    font-size: 13px;
    font-weight: 500;
    color: #202020;
    background: transparent;
    border: none;
    padding: 0px;
}

/* 输入框样式 - Windows 11风格 */
QLineEdit {
    border: 1px solid #E1E1E1;
    border-radius: 4px;
    padding: 10px 12px;
    font-size: 14px;
    background-color: #FFFFFF;
    color: #202020;
    min-height: 20px;
    selection-background-color: #0078D4;
    selection-color: #FFFFFF;
}

QLineEdit:focus {
    border: 2px solid #0078D4;
    padding: 9px 11px;
    background-color: #FFFFFF;
}

QLineEdit:hover:!focus {
    border-color: #C1C1C1;
}

QLineEdit:disabled {
    background-color: #F3F3F3;
    color: #A0A0A0;
    border-color: #E1E1E1;
}

/* 下拉框样式 */
QComboBox {
    border: 1px solid #E1E1E1;
    border-radius: 4px;
    padding: 10px 12px;
    font-size: 14px;
    background-color: #FFFFFF;
    color: #202020;
    min-height: 20px;
    selection-background-color: #0078D4;
    selection-color: #FFFFFF;
}

QComboBox:focus {
    border: 2px solid #0078D4;
    padding: 9px 11px;
}

QComboBox:hover:!focus {
    border-color: #C1C1C1;
}

QComboBox::drop-down {
    border: none;
    width: 30px;
    background-color: transparent;
}

QComboBox::down-arrow {
    width: 12px;
    height: 12px;
}

QComboBox QAbstractItemView {
    border: 1px solid #E1E1E1;
    border-radius: 4px;
    background-color: #FFFFFF;
    selection-background-color: #E8F4FD;
    selection-color: #202020;
    padding: 4px;
}

/* 复选框样式 */
QCheckBox {
    font-size: 14px;
    font-weight: 400;
    color: #202020;
    spacing: 10px;
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border: 2px solid #606060;
    border-radius: 3px;
    background-color: #FFFFFF;
}

QCheckBox::indicator:hover {
    border-color: #0078D4;
}

QCheckBox::indicator:checked {
    background-color: #0078D4;
    border-color: #0078D4;
    image: none;
}

/* 按钮样式 */
QPushButton#saveButton {
    background-color: #0078D4;
    border: none;
    border-radius: 4px;
    color: #FFFFFF;
    font-size: 14px;
    font-weight: 500;
    padding: 10px 24px;
    min-height: 36px;
    min-width: 100px;
}

QPushButton#saveButton:hover {
    background-color: #106EBE;
}

QPushButton#saveButton:pressed {
    background-color: #005A9E;
}

QPushButton#saveButton:disabled {
    background-color: #E1E1E1;
    color: #A0A0A0;
}

QPushButton#cancelButton {
    background-color: transparent;
    border: 1px solid #E1E1E1;
    border-radius: 4px;
    color: #202020;
    font-size: 14px;
    font-weight: 500;
    padding: 10px 24px;
    min-height: 36px;
    min-width: 100px;
}

QPushButton#cancelButton:hover {
    background-color: #F9F9F9;
    border-color: #C1C1C1;
}

QPushButton#cancelButton:pressed {
    background-color: #F3F3F3;
}

/* 提示文本 */
QLabel#hintLabel, QLabel#studentHintLabel, QLabel#teacherHintLabel, QLabel#settingsHintLabel {
    font-size: 12px;
    font-weight: 400;
    color: #606060;
    font-style: italic;
    background: transparent;
    border: none;
    padding: 0px;
}

/* 分隔线 */
QFrame#divider {
    background-color: #E1E1E1;
    max-height: 1px;
    min-height: 1px;
    border: none;
}</string>
